:root {
  color-scheme: light;
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  background: #f4f7fb;
  color: #0f172a;
  line-height: 1.6;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  min-height: 100vh;
  background: radial-gradient(circle at top left, rgba(99, 102, 241, 0.14), transparent 23%),
              radial-gradient(circle at 85% 12%, rgba(59, 130, 246, 0.1), transparent 18%),
              radial-gradient(circle at 50% 92%, rgba(59, 130, 246, 0.06), transparent 28%),
              #eef2ff;
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input {
  font: inherit;
}

.app-shell {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px 48px;
}

html {
  scroll-behavior: smooth;
}

.topbar {
  width: 100%;
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.98);
  color: #0f172a;
  border-bottom: 1px solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 2px 8px rgba(2, 6, 23, 0.04);
}

.topbar-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 24px;
}

.brand {
  font-size: 1.1rem;
  font-weight: 800;
  letter-spacing: 0.04em;
  color: #0f172a;
}

.nav-links {
  display: flex;
  gap: 24px;
  flex-wrap: nowrap;
  flex: 1;
  justify-content: space-between;
  max-width: 720px;
}

.nav-links a {
  color: #0f172a;
  font-weight: 700;
  transition: color 0.15s ease, transform 0.15s ease;
}

.nav-links a:hover {
  color: #1e3a8a;
  transform: translateY(-2px);
}

.hero {
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
  gap: 32px;
  align-items: center;
  padding: 72px 36px;
  background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 96%);
  border-radius: 32px;
  color: white;
  margin-bottom: 40px;
  box-shadow: 0 36px 90px rgba(15, 23, 42, 0.18);
  backdrop-filter: blur(22px);
  border: 1px solid rgba(255, 255, 255, 0.12);
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  width: 520px;
  height: 520px;
  border-radius: 50%;
  background: rgba(99, 102, 241, 0.18);
  top: -160px;
  right: -120px;
  filter: blur(80px);
  pointer-events: none;
}

.hero::after {
  content: '';
  position: absolute;
  width: 320px;
  height: 320px;
  border-radius: 50%;
  background: rgba(59, 130, 246, 0.12);
  bottom: -120px;
  left: -80px;
  filter: blur(64px);
  pointer-events: none;
}

.hero-copy {
  max-width: 620px;
}

.hero .eyebrow {
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: #c7d2fe;
  margin-bottom: 20px;
  font-size: 0.85rem;
}

.hero h1 {
  font-size: clamp(2.25rem, 4vw, 3.75rem);
  margin: 0 0 24px;
  line-height: 1.05;
}

.hero p {
  font-size: 1.05rem;
  margin: 0 0 32px;
  max-width: 560px;
}

.hero-actions {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 28px;
}

.hero-badges span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10px 16px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.18);
  color: #e2e8f0;
  font-size: 0.95rem;
  font-weight: 600;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 24px;
  border-radius: 999px;
  font-weight: 700;
  transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  box-shadow: 0 10px 24px rgba(15, 23, 42, 0.12);
}

.btn-primary {
  background: #f8fafc;
  color: #1e3a8a;
}

.btn-secondary {
  background: rgba(255,255,255,0.16);
  color: white;
  border: 1px solid rgba(255,255,255,0.25);
}

.btn:hover {
  transform: translateY(-2px);
}

.reveal-on-scroll {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.75s ease, transform 0.75s ease;
  will-change: opacity, transform;
}

.reveal-visible {
  opacity: 1;
  transform: translateY(0);
}


.quick-card:nth-child(1) {
  transition-delay: 0.20s;
}

.quick-card:nth-child(2) {
  transition-delay: 0.26s;
}

.quick-card:nth-child(3) {
  transition-delay: 0.32s;
}

.quick-card:nth-child(4) {
  transition-delay: 0.38s;
}

.card:nth-child(1) {
  transition-delay: 0.22s;
}

.card:nth-child(2) {
  transition-delay: 0.28s;
}

.card:nth-child(3) {
  transition-delay: 0.34s;
}

.card:nth-child(4) {
  transition-delay: 0.40s;
}

.card:nth-child(5) {
  transition-delay: 0.46s;
}

.card:nth-child(6) {
  transition-delay: 0.52s;
}

.testimonial-card:nth-child(1) {
  transition-delay: 0.30s;
}

.testimonial-card:nth-child(2) {
  transition-delay: 0.36s;
}

.testimonial-card:nth-child(3) {
  transition-delay: 0.42s;
}

.newsletter-card {
  transition-delay: 0.38s;
}

.contact-card {
  transition-delay: 0.44s;
}

.floating-contact {
  animation: floatButton 3s ease-in-out infinite alternate;
}

@keyframes fadeUp {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes floatButton {
  from {
    transform: translateY(0);
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.18);
  }
  to {
    transform: translateY(-6px);
    box-shadow: 0 24px 52px rgba(15, 23, 42, 0.24);
  }
}

.quick-access {
  padding-top: 0;
  margin-top: -12px;
}

.help-strip {
  background: linear-gradient(135deg, rgba(248, 250, 252, 0.96), rgba(226, 232, 240, 0.88));
  border-radius: 28px;
  padding: 28px 32px;
  margin-bottom: 24px;
  border: 1px solid rgba(148, 163, 184, 0.18);
  backdrop-filter: blur(14px);
}

.help-strip-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 16px;
}

.help-strip p {
  margin: 0;
  font-weight: 700;
  color: #0f172a;
}

.help-strip-actions {
  display: flex;
  align-items: center;
  gap: 18px;
  flex-wrap: wrap;
}

.help-strip-actions span {
  color: #334155;
}

.help-strip .btn-secondary {
  background: #000000;
  color: #ffffff;
  border: none;
  padding: 12px 18px;
  box-shadow: 0 12px 36px rgba(0,0,0,0.18);
  transition: transform 0.12s ease, box-shadow 0.12s ease, background 0.12s ease;
}

.help-strip .btn-secondary:hover {
  transform: translateY(-3px);
  box-shadow: 0 18px 46px rgba(0,0,0,0.22);
  background: #111111;
}

.hero-panel {
  display: grid;
  gap: 20px;
}

.hero-panel-card {
  background: rgba(255,255,255,0.14);
  border: 1px solid rgba(255,255,255,0.24);
  border-radius: 24px;
  padding: 28px;
  backdrop-filter: blur(18px);
}

.hero-panel-card p {
  margin: 0 0 12px;
  color: #dbeafe;
  font-weight: 700;
}

.hero-panel-card h3 {
  margin: 0;
  font-size: 1.05rem;
}

.hero-panel-card:hover,
.card:hover,
.quick-card:hover,
.testimonial-card:hover,
.about-card:hover,
.newsletter-card:hover,
.contact-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 26px 60px rgba(15, 23, 42, 0.18);
}

.section {
  padding: 40px 0;
}

.quick-access {
  padding-top: 0;
  margin-top: -16px;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 20px;
}

.quick-card {
  background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
  border-radius: 28px;
  padding: 26px;
  box-shadow: 0 22px 48px rgba(15, 23, 42, 0.08);
  border: 1px solid rgba(99, 102, 241, 0.12);
}

.quick-card h3 {
  margin: 0 0 14px;
  color: #0f172a;
}

.quick-card p {
  margin: 0 0 20px;
  color: #475569;
}

.quick-link {
  display: inline-flex;
  align-items: center;
  color: #1e3a8a;
  font-weight: 700;
}

.quick-link:hover {
  text-decoration: underline;
}

.section-heading {
  max-width: 760px;
  margin-bottom: 28px;
}

.section-heading .eyebrow {
  margin-bottom: 12px;
  color: #0f172a;
}

.section-heading h2 {
  font-size: clamp(2rem, 3vw, 2.75rem);
  margin: 0;
}

.contact-heading {
  max-width: 760px;
  margin-bottom: 24px;
}

.contact-subheading {
  margin-top: 10px;
  font-size: 1.02rem;
  color: #475569;
  line-height: 1.7;
}

.stats {
  background: #fff;
  border-radius: 28px;
  padding: 32px;
  margin-bottom: 40px;
}

.stats-grid {
  display: grid;
  gap: 24px;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
}

.stats-grid div {
  text-align: center;
}

.stats-grid strong {
  display: block;
  font-size: 2rem;
  color: #1e3a8a;
}

.services .cards-grid,
.testimonials-grid {
  display: grid;
  gap: 24px;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
}

.card,
.testimonial-card,
.about-card,
.newsletter-card,
.quick-card,
.hero-panel-card {
  background: rgba(255, 255, 255, 0.75);
  border-radius: 28px;
  padding: 28px;
  box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(16px);
  transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease, background-color 0.25s ease;
}

.card h3,
.about-card h3 {
  margin-top: 0;
}

.card p,
.about-card p,
.testimonial-card p,
.contact-card p {
  margin: 0;
  color: #475569;
}

.about.split {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 32px;
  align-items: start;
}

.about-list {
  margin: 24px 0 0;
  padding: 0;
  list-style: none;
  display: grid;
  gap: 12px;
}

.about-list li {
  padding-left: 18px;
  position: relative;
}

.about-list li::before {
  content: '•';
  position: absolute;
  left: 0;
  color: #1e40af;
}

.about-panel {
  display: grid;
  gap: 20px;
}

.team {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 12px;
}

.team-member {
  background: rgba(255,255,255,0.95);
  border-radius: 12px;
  padding: 10px 14px;
  box-shadow: 0 8px 20px rgba(2,6,23,0.06);
  display: flex;
  flex-direction: column;
  gap: 6px;
  min-width: 160px;
}

.team-member strong {
  color: var(--text);
}

.team-member span {
  color: var(--muted);
  font-size: 0.95rem;
}

.testimonials {
  background: rgba(15, 23, 42, 0.04);
  border-radius: 28px;
  padding: 32px;
}

.testimonial-card {
  border-left: 4px solid #1e3a8a;
}

.testimonial-card span {
  display: block;
  margin-top: 20px;
  font-weight: 700;
  color: #0f172a;
}

.newsletter {
  padding: 0;
}

.newsletter-card {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 24px;
  background: #1e3a8a;
  color: white;
  padding: 36px;
}

.floating-contact {
  position: fixed;
  right: 24px;
  bottom: 24px;
  z-index: 110;
  background: #1e3a8a;
  color: white;
  padding: 14px 18px;
  border-radius: 999px;
  text-decoration: none;
  box-shadow: 0 18px 40px rgba(15, 23, 42, 0.18);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.floating-contact:hover {
  transform: translateY(-2px);
  box-shadow: 0 24px 52px rgba(15, 23, 42, 0.22);
}

.newsletter-form {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}

.newsletter-form input {
  flex: 1;
  min-width: 200px;
  border: none;
  border-radius: 999px;
  padding: 16px 18px;
}

.newsletter-form button {
  border: none;
}

.contact-card {
  display: grid;
  grid-template-columns: repeat(2, minmax(280px, 1fr));
  gap: 28px;
  padding: 32px;
  background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 100%);
  color: white;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.contact-details {
  display: grid;
  gap: 18px;
  align-content: start;
}

.contact-item {
  padding: 16px 18px;
  border-radius: 16px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.14);
}

.contact-card h3 {
  margin: 0 0 8px;
  font-size: 1rem;
}

.contact-card p {
  line-height: 1.7;
}

.contact-form-card {
  margin-top: 24px;
  background: rgba(255, 255, 255, 0.9);
  border: 1px solid rgba(148, 163, 184, 0.18);
  border-radius: 28px;
  padding: 28px;
  box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
}

.contact-form-intro h3 {
  margin: 6px 0 8px;
  font-size: 1.35rem;
}

.contact-form-intro p {
  margin: 0;
  color: #475569;
}

.contact-form {
  display: grid;
  gap: 16px;
  margin-top: 20px;
}

.form-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16px;
}

.contact-form label {
  display: grid;
  gap: 8px;
  font-weight: 600;
  color: #0f172a;
}

.contact-form input,
.contact-form textarea {
  width: 100%;
  border: 1px solid rgba(148, 163, 184, 0.35);
  border-radius: 14px;
  padding: 12px 14px;
  background: #fff;
  color: #0f172a;
}

.contact-form textarea {
  resize: vertical;
  min-height: 120px;
}

.contact-form .btn-primary {
  justify-self: start;
  border: none;
  cursor: pointer;
}

.contact-form .btn-primary:disabled {
  opacity: 0.7;
  cursor: wait;
}

.form-status {
  margin: 0;
  font-size: 0.95rem;
  font-weight: 600;
}

.form-status.success {
  color: #166534;
}

.form-status.error {
  color: #b91c1c;
}

.map-card {
  border-radius: 24px;
  overflow: hidden;
  min-height: 340px;
  border: 1px solid rgba(255, 255, 255, 0.18);
}

.map-card iframe {
  width: 100%;
  height: 100%;
  min-height: 320px;
  border: 0;
}

.footer {
  text-align: center;
  color: #64748b;
  padding: 32px 0 12px;
}

@media (max-width: 900px) {
  .hero,
  .about.split,
  .newsletter-card {
    grid-template-columns: 1fr;
  }

  .hero {
    padding: 36px 24px;
  }
}

@media (max-width: 640px) {
  .app-shell {
    padding: 0 16px 32px;
  }

  .contact-card {
    padding: 24px;
  }

  .contact-item {
    padding: 14px 15px;
  }

  .form-row {
    grid-template-columns: 1fr;
  }

  .topbar {
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .nav-links {
    gap: 14px;
  }

  .hero h1 {
    font-size: 2.4rem;
  }

  .stats-grid,
  .services .cards-grid,
  .testimonials-grid,
  .contact-card {
    grid-template-columns: 1fr;
  }

  .newsletter-card {
    padding: 28px;
  }
}
